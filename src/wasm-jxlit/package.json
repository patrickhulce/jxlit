{
  "name": "@jxlit/wasm",
  "version": "0.1.0",
  "description": "WebAssembly bindings for jxlit",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "license": "MIT",
  "files": [
    "dist",
    "pkg"
  ],
  "scripts": {
    "build:wasm": "wasm-pack build --target nodejs --out-dir pkg",
    "build:ts": "tsc",
    "build": "pnpm run build:wasm && pnpm run build:ts",
    "benchmark": "node --experimental-wasm-modules --import tsx src/benchmark.ts",
    "test": "node --experimental-wasm-modules --import tsx --test test/decode.test.ts",
    "lint": "eslint . && prettier --check .",
    "lint:fix": "eslint --fix . && prettier --write .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.test.json"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "@types/pngjs": "^6.0.5",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
